---
title: "发布文章 - PNDS BOM Hub"
---

<!doctype html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width" />
  <title>发布文章 - PNDS BOM Hub</title>
  <style>
    * { box-sizing: border-box; margin: 0; padding: 0; }
    body { font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif; background-color: #111827; color: #fff; }
    .min-h-screen { min-height: 100vh; }
    .bg-gray-900 { background-color: #111827; }
    .fixed { position: fixed; }
    .left-0 { left: 0; }
    .top-0 { top: 0; }
    .h-screen { height: 100vh; }
    .w-64 { width: 16rem; }
    .bg-gray-800 { background-color: #1f2937; }
    .border-r { border-right-width: 1px; }
    .border-gray-700 { border-color: #374151; }
    .p-6 { padding: 1.5rem; }
    .flex { display: flex; }
    .items-center { align-items: center; }
    .space-x-3 > * + * { margin-left: 0.75rem; }
    .w-10 { width: 2.5rem; }
    .h-10 { height: 2.5rem; }
    .bg-gradient-to-r { background: linear-gradient(90deg, #f59e0b, #ea580c); }
    .rounded-lg { border-radius: 0.5rem; }
    .justify-center { justify-content: center; }
    .text-lg { font-size: 1.125rem; }
    .font-bold { font-weight: 700; }
    .text-white { color: #fff; }
    .text-xs { font-size: 0.75rem; }
    .text-gray-400 { color: #9ca3af; }
    .p-4 { padding: 1rem; }
    .space-y-2 > * + * { margin-top: 0.5rem; }
    .w-full { width: 100%; }
    .px-4 { padding-left: 1rem; padding-right: 1rem; }
    .py-3 { padding-top: 0.75rem; padding-bottom: 0.75rem; }
    .bg-amber-500\/20 { background-color: rgba(245, 158, 11, 0.2); }
    .text-amber-400 { color: #fbbf24; }
    .hover-bg-gray-700:hover { background-color: rgba(55, 65, 81, 0.5); }
    .transition-colors { transition: color 0.2s, background-color 0.2s; }
    .absolute { position: absolute; }
    .bottom-0 { bottom: 0; }
    .right-0 { right: 0; }
    .border-t { border-top-width: 1px; }
    .text-gray-300 { color: #d1d5db; }
    .ml-64 { margin-left: 16rem; }
    .mb-8 { margin-bottom: 2rem; }
    .text-2xl { font-size: 1.5rem; }
    .font-semibold { font-weight: 600; }
    .mt-1 { margin-top: 0.25rem; }
    .mt-4 { margin-top: 1rem; }
    .mt-6 { margin-top: 1.5rem; }
    .cursor-pointer { cursor: pointer; }
    .header-bar { position: fixed; top: 0; right: 0; left: 16rem; height: 4rem; background-color: rgba(31, 41, 55, 0.9); border-bottom: 1px solid #374151; display: flex; align-items: center; justify-content: flex-end; padding: 0 2rem; z-index: 50; }
    .user-info { display: flex; align-items: center; gap: 0.75rem; }
    .user-avatar { width: 2.5rem; height: 2.5rem; border-radius: 9999px; background: linear-gradient(90deg, #f59e0b, #ea580c); display: flex; align-items: center; justify-content: center; font-weight: 700; }
    .user-details { text-align: right; }
    .user-name { font-weight: 500; color: #fff; }
    .user-role { font-size: 0.75rem; color: #9ca3af; }
    .content-area { margin-top: 4rem; padding: 2rem; }
    .card { background: #1f2937; border-radius: 1rem; padding: 2rem; border: 1px solid #374151; }
    .form-group { margin-bottom: 1.5rem; }
    .form-label { display: block; margin-bottom: 0.5rem; font-size: 0.875rem; color: #d1d5db; font-weight: 500; }
    .form-input { width: 100%; padding: 0.75rem 1rem; background: #374151; border: 1px solid #4b5563; border-radius: 0.5rem; color: #fff; font-size: 0.875rem; }
    .form-input:focus { border-color: #f59e0b; outline: none; }
    .form-textarea { width: 100%; padding: 0.75rem 1rem; background: #374151; border: 1px solid #4b5563; border-radius: 0.5rem; color: #fff; font-size: 0.875rem; min-height: 250px; resize: vertical; font-family: inherit; }
    .form-textarea:focus { border-color: #f59e0b; outline: none; }
    .btn { padding: 0.75rem 1.5rem; border-radius: 0.5rem; font-weight: 600; cursor: pointer; border: none; transition: all 0.2s; font-size: 1rem; }
    .btn-primary { background: linear-gradient(90deg, #f59e0b, #ea580c); color: #000; }
    .btn-primary:hover { background: linear-gradient(90deg, #d97706, #c2410c); }
    .btn-secondary { background: #4b5563; color: #fff; }
    .btn-secondary:hover { background: #6b7280; }
    .gap-4 { gap: 1rem; }
    .grid-cols-2 { grid-template-columns: repeat(2, minmax(0, 1fr)); }
    .grid { display: grid; }
    .section-title { font-size: 1.125rem; font-weight: 600; color: #fbbf24; margin-bottom: 1rem; padding-bottom: 0.5rem; border-bottom: 1px solid #374151; }
    .tip { background: rgba(34, 197, 94, 0.1); border: 1px solid rgba(34, 197, 94, 0.3); padding: 1rem; border-radius: 0.5rem; margin-bottom: 1.5rem; }
    .tip-text { color: #4ade80; font-size: 0.875rem; }
    .hidden { display: none !important; }
    .active-nav { background-color: rgba(245, 158, 11, 0.2); color: #fbbf24; }
    .default-nav { color: #d1d5db; }
    .language-switcher { display: flex; gap: 0.5rem; margin-bottom: 1rem; }
    .lang-btn { padding: 0.5rem 1rem; border-radius: 0.5rem; border: 1px solid #4b5563; background: #374151; color: #9ca3af; cursor: pointer; transition: all 0.2s; font-size: 0.875rem; }
    .lang-btn.active { background: rgba(245, 158, 11, 0.2); color: #fbbf24; border-color: #f59e0b; }
    .lang-btn:hover { border-color: #f59e0b; color: #fff; }
    .ai-badge { display: inline-flex; align-items: center; gap: 0.5rem; padding: 0.25rem 0.75rem; background: rgba(139, 92, 246, 0.15); border: 1px solid rgba(139, 92, 246, 0.3); border-radius: 9999px; font-size: 0.75rem; color: #a78bfa; margin-left: 1rem; }
    .category-selector { display: flex; flex-wrap: wrap; gap: 0.5rem; }
    .category-btn { padding: 0.5rem 1.25rem; border-radius: 0.5rem; border: 1px solid #4b5563; background: #374151; color: #9ca3af; cursor: pointer; transition: all 0.2s; font-size: 0.875rem; display: flex; align-items: center; gap: 0.5rem; }
    .category-btn.active { background: rgba(245, 158, 11, 0.2); color: #fbbf24; border-color: #f59e0b; }
    .category-btn:hover:not(.disabled) { border-color: #f59e0b; color: #fff; }
    .category-btn.disabled { opacity: 0.5; cursor: not-allowed; }
    .category-btn.disabled:hover { border-color: #4b5563; color: #9ca3af; }
    .category-icon { font-size: 1rem; }
  </style>
</head>
<body>
  <div class="min-h-screen bg-gray-900">
    <div class="fixed left-0 top-0 h-screen w-64 bg-gray-800 border-r border-gray-700">
      <div class="p-6">
        <div class="flex items-center space-x-3">
          <div class="w-10 h-10 bg-gradient-to-r rounded-lg flex items-center justify-center">
            <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"/>
            </svg>
          </div>
          <div>
            <h1 class="text-lg font-bold text-white">PNDS Hub</h1>
            <p class="text-xs text-gray-400">内容管理</p>
          </div>
        </div>
      </div>
      
      <nav class="p-4 space-y-2">
        <button id="nav-back" class="w-full px-4 py-3 default-nav hover-bg-gray-700 rounded-lg font-medium flex items-center space-x-3 transition-colors cursor-pointer">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"/></svg>
          <span>返回工作台</span>
        </button>
        <button id="nav-create" class="w-full px-4 py-3 active-nav rounded-lg font-medium flex items-center space-x-3 transition-colors cursor-pointer">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/></svg>
          <span>发布文章</span>
        </button>
      </nav>
      
      <div class="absolute bottom-0 left-0 right-0 p-4 border-t border-gray-700">
        <button id="logoutBtn" class="w-full px-4 py-3 text-gray-400 hover:text-white hover-bg-gray-700 rounded-lg font-medium flex items-center space-x-3 transition-colors cursor-pointer">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1"/></svg>
          <span>退出登录</span>
        </button>
      </div>
    </div>

    <div class="header-bar">
      <div class="user-info">
        <div class="user-details">
          <div class="user-name" id="userName">用户</div>
          <div class="user-role" id="userRole">普通用户</div>
        </div>
        <div class="user-avatar" id="userAvatar">U</div>
      </div>
    </div>

    <div class="ml-64 content-area">
      <div class="mb-8">
        <h2 class="text-2xl font-bold text-white">发布技术文章</h2>
        <p class="text-gray-400 mt-1">分享您的专业知识，AI自动完成双语翻译</p>
      </div>

      <div class="tip">
        <p class="tip-text">✨ 智能发布：您只需用一种语言写作，AI会自动将其翻译成另一种语言，并生成专业的SEO关键词，让全球用户都能看到您的文章！</p>
      </div>

      <div class="card">
        <form id="postForm">
          <div class="section-title">📁 选择发布板块</div>
          
          <div class="category-selector" id="categorySelector">
          </div>

          <div class="section-title" style="margin-top: 2.5rem;">🌐 选择写作语言</div>
          
          <div class="language-switcher">
            <button type="button" id="langCn" class="lang-btn active" onclick="setLanguage('cn')">
              🇨🇳 中文写作
            </button>
            <button type="button" id="langEn" class="lang-btn" onclick="setLanguage('en')">
              🇬🇧 English
            </button>
          </div>

          <div class="section-title" style="margin-top: 2rem;">📝 文章标题 <span id="langIndicator" class="ai-badge">AI 将自动翻译</span></div>
          
          <div class="form-group">
            <label class="form-label" id="titleLabel">中文标题 *</label>
            <input type="text" class="form-input" id="titleInput" required placeholder="请输入文章标题，建议包含产品型号或关键词" />
          </div>

          <div class="section-title" style="margin-top: 2rem;">📄 文章正文</div>
          
          <div class="form-group">
            <label class="form-label" id="contentLabel">中文正文 *</label>
            <textarea class="form-textarea" id="contentInput" required placeholder="请输入文章内容，可以包含技术分析、产品对比、应用案例、华强北防坑指南等"></textarea>
          </div>

          <div class="section-title" style="margin-top: 2rem;">🏷️ 可选关键词</div>
          
          <div class="form-group">
            <label class="form-label">补充关键词（可选）</label>
            <input type="text" class="form-input" id="keywords" placeholder="输入相关关键词，AI会自动补充更多优质关键词" />
          </div>

          <div class="flex gap-4 mt-6">
            <button type="submit" class="btn btn-primary flex-1" id="submitBtn">提交审核</button>
            <button type="button" class="btn btn-secondary flex-1" onclick="document.getElementById('postForm').reset(); setLanguage('cn'); selectCategory();">重置表单</button>
          </div>
        </form>
      </div>
    </div>

    <div id="successModal" style="position: fixed; top: 0; left: 0; right: 0; bottom: 0; background: rgba(0,0,0,0.7); z-index: 1000; display: none; align-items: center; justify-content: center;">
      <div style="background: #1f2937; border-radius: 1rem; padding: 2rem; max-width: 500px; width: 90%; text-align: center;">
        <div style="width: 64px; height: 64px; background: rgba(34, 197, 94, 0.2); border-radius: 9999px; display: flex; align-items: center; justify-content: center; margin: 0 auto 1.5rem;">
          <svg class="w-8 h-8 text-green-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
        </div>
        <h3 style="font-size: 1.25rem; font-weight: 600; color: #fff; margin-bottom: 0.5rem;">提交成功！</h3>
        <p style="color: #9ca3af; margin-bottom: 1.5rem;" id="successMessage">您的文章已成功提交，等待管理员审核通过后即可发布。</p>
        <button id="closeSuccessModal" class="btn btn-primary">确定</button>
      </div>
    </div>

    <script>
      let currentUser = null;
      let userRole = null;
      let currentLanguage = 'cn';
      let currentCategory = 'domestic_vs_global';

      const CATEGORIES = {
        domestic_vs_global: { name: '国产 VS 全球', nameEn: 'Domestic vs Global', icon: '🌍', description: '国产芯片与进口芯片对比分析' },
        about_us: { name: '关于我们', nameEn: 'About Us', icon: '🏢', description: '公司介绍与行业感悟' },
        bom_optimization: { name: 'BOM优化', nameEn: 'BOM Optimization', icon: '🔧', description: 'BOM成本优化与替代方案' }
      };

      const ROLE_CATEGORIES = {
        admin: ['domestic_vs_global', 'about_us'],
        sales: ['domestic_vs_global'],
        customer: ['domestic_vs_global', 'bom_optimization']
      };

      function getDashboardUrl() {
        if (userRole === 'admin') return '/dashboard/admin';
        if (userRole === 'sales') return '/dashboard/sales';
        if (userRole === 'customer') return '/dashboard/customer';
        return '/login';
      }

      function renderCategorySelector() {
        const selector = document.getElementById('categorySelector');
        const allowedCategories = ROLE_CATEGORIES[userRole] || [];
        
        let html = '';
        for (const [key, cat] of Object.entries(CATEGORIES)) {
          const isAllowed = allowedCategories.includes(key);
          const isActive = key === currentCategory;
          
          if (isAllowed) {
            html += `
              <button 
                type="button" 
                class="category-btn ${isActive ? 'active' : ''}" 
                onclick="selectCategory('${key}')"
                title="${cat.description}"
              >
                <span class="category-icon">${cat.icon}</span>
                <span>${cat.name}</span>
              </button>
            `;
          }
        }
        
        selector.innerHTML = html;
        
        if (allowedCategories.length === 1) {
          currentCategory = allowedCategories[0];
        }
      }

      function selectCategory(category) {
        currentCategory = category || currentCategory;
        
        const buttons = document.querySelectorAll('.category-btn');
        buttons.forEach(btn => {
          btn.classList.remove('active');
        });
        
        const activeBtn = document.querySelector(`.category-btn[onclick*="${currentCategory}"]`);
        if (activeBtn) {
          activeBtn.classList.add('active');
        }
      }

      function setLanguage(lang) {
        currentLanguage = lang;
        
        document.getElementById('langCn').classList.toggle('active', lang === 'cn');
        document.getElementById('langEn').classList.toggle('active', lang === 'en');
        
        if (lang === 'cn') {
          document.getElementById('titleLabel').textContent = '中文标题 *';
          document.getElementById('contentLabel').textContent = '中文正文 *';
          document.getElementById('titleInput').placeholder = '请输入文章标题，建议包含产品型号或关键词';
          document.getElementById('contentInput').placeholder = '请输入文章内容，可以包含技术分析、产品对比、应用案例、华强北防坑指南等';
        } else {
          document.getElementById('titleLabel').textContent = 'English Title *';
          document.getElementById('contentLabel').textContent = 'English Content *';
          document.getElementById('titleInput').placeholder = 'Enter article title, include product model or keywords';
          document.getElementById('contentInput').placeholder = 'Enter article content, can include technical analysis, product comparison, application cases, etc.';
        }
      }

      async function handleSubmit(e) {
        e.preventDefault();

        const submitBtn = document.getElementById('submitBtn');
        submitBtn.disabled = true;
        submitBtn.textContent = 'AI 智能翻译中...';

        try {
          const title = document.getElementById('titleInput').value;
          const content = document.getElementById('contentInput').value;
          const keywords = document.getElementById('keywords').value || '';

          const response = await fetch('/api/blogs/submit', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ 
              title, 
              content, 
              keywords,
              language: currentLanguage,
              category: currentCategory
            })
          });

          const result = await response.json();

          if (result.success) {
            const messageEl = document.getElementById('successMessage');
            messageEl.textContent = result.message;
            document.getElementById('successModal').style.display = 'flex';
            document.getElementById('postForm').reset();
            setLanguage('cn');
            selectCategory();
          } else {
            alert('提交失败：' + (result.message || result.error || '未知错误'));
          }
        } catch (error) {
          console.error('Error:', error);
          alert('提交失败，请稍后重试');
        } finally {
          submitBtn.disabled = false;
          submitBtn.textContent = '提交审核';
        }
      }

      document.addEventListener('DOMContentLoaded', function() {
        const userData = localStorage.getItem('currentUser');
        if (userData) {
          try {
            currentUser = JSON.parse(userData);
            userRole = currentUser.role;
            document.getElementById('userName').textContent = currentUser.name || '用户';
            document.getElementById('userRole').textContent = userRole === 'admin' ? '系统管理员' : (userRole === 'sales' ? '普通业务员' : '客户');
            document.getElementById('userAvatar').textContent = (currentUser.name || 'U').charAt(0).toUpperCase();
            
            renderCategorySelector();
          } catch (e) {
            console.error('Failed to parse user data', e);
            window.location.href = '/login';
            return;
          }
        } else {
          window.location.href = '/login';
          return;
        }
        
        document.getElementById('nav-back').addEventListener('click', function() {
          window.location.href = getDashboardUrl();
        });
        
        document.getElementById('logoutBtn').addEventListener('click', function() {
          localStorage.removeItem('currentUser');
          window.location.href = '/login';
        });
        
        document.getElementById('postForm').addEventListener('submit', handleSubmit);
        
        document.getElementById('closeSuccessModal').addEventListener('click', function() {
          document.getElementById('successModal').style.display = 'none';
        });
      });
    </script>
  </body>
</html>
