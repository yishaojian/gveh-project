        `;
        document.getElementById('blogDetailContent').innerHTML = content;
        document.getElementById('blogDetailModal').classList.add('active');
      }

      function closeBlogDetailModal() {
        document.getElementById('blogDetailModal').classList.remove('active');
      }

      function openAddSalesModal() {
        document.getElementById('salesModalTitle').textContent = '添加业务员';
        document.getElementById('salesId').value = '';
        document.getElementById('salesForm').reset();
        document.getElementById('salesModal').classList.add('active');
      }

      function editSales(id) {
        const sales = salesTeam.find(function(s) { return s.id === id; });
        if (!sales) return;
        document.getElementById('salesModalTitle').textContent = '编辑业务员';
        document.getElementById('salesId').value = sales.id;
        document.getElementById('salesName').value = sales.name;
        document.getElementById('salesEmail').value = sales.email;
        document.getElementById('salesPhone').value = sales.phone || '';
        document.getElementById('salesWechat').value = sales.wechat || '';
        document.getElementById('salesRegion').value = sales.region;
        document.getElementById('salesModal').classList.add('active');
      }

      function closeSalesModal() {
        document.getElementById('salesModal').classList.remove('active');
      }

      function handleSalesSubmit(e) {
        e.preventDefault();
        const id = document.getElementById('salesId').value;
        const data = {
          name: document.getElementById('salesName').value,
          email: document.getElementById('salesEmail').value,
          phone: document.getElementById('salesPhone').value,
          wechat: document.getElementById('salesWechat').value,
          region: document.getElementById('salesRegion').value
        };

        if (id) {
          const index = salesTeam.findIndex(function(s) { return s.id === id; });
          if (index !== -1) salesTeam[index] = Object.assign({}, salesTeam[index], data);
        } else {
          salesTeam.push(Object.assign({ id: 'sales-' + Date.now(), performance_total: 0, status: 'active' }, data));
        }
        closeSalesModal();
        renderSalesTable();
        renderDashboard();
        alert(id ? '业务员信息已更新' : '业务员添加成功');
      }

      function deleteSales(id) {
        if (!confirm('确定要删除该业务员吗？')) return;
        salesTeam = salesTeam.filter(function(s) { return s.id !== id; });
        renderSalesTable();
        renderDashboard();
        alert('业务员已删除');
      }

      function viewSalesQuotes(salesId) {
        const sales = salesTeam.find(function(s) { return s.id === salesId; });
        const quotes = allOrders.filter(function(o) { return o.assigned_sales_id === salesId; });
        const details = document.getElementById('quoteDetails');
        
        let quoteRows = '';
        if (quotes.length === 0) {
          quoteRows = '<tr><td colspan="5" class="px-4 py-8 text-center text-gray-400">暂无报价记录</td></tr>';
        } else {
          quoteRows = quotes.map(function(q) {
            return '<tr><td class="px-4 py-3 text-sm text-gray-300 font-mono">' + q.id + '</td><td class="px-4 py-3 text-sm text-gray-300">' + q.customer_email + '</td><td class="px-4 py-3 text-sm text-gray-300">¥' + (q.quote_amount ? q.quote_amount.toLocaleString() : '-') + '</td><td class="px-4 py-3"><span class="badge ' + statusColors[q.status] + '">' + statusLabels[q.status] + '</span></td><td class="px-4 py-3 text-sm text-gray-400">' + new Date(q.created_at).toLocaleDateString('zh-CN') + '</td></tr>';
          }).join('');
        }

        details.innerHTML = '<div class="mb-4"><p class="text-gray-400">业务员：<span class="text-white">' + (sales ? sales.name : '') + '</span></p><p class="text-gray-400">邮箱：<span class="text-white">' + (sales ? sales.email : '') + '</span></p><p class="text-gray-400">总业绩：<span class="text-amber-400">¥' + (sales ? sales.performance_total.toLocaleString() : '0') + '</span></p></div><div class="overflow-x-auto"><table class="w-full"><thead><tr style="background-color: rgba(55, 65, 81, 0.5);"><th class="px-4 py-3 text-left text-xs font-medium text-gray-400 uppercase">订单号</th><th class="px-4 py-3 text-left text-xs font-medium text-gray-400 uppercase">客户</th><th class="px-4 py-3 text-left text-xs font-medium text-gray-400 uppercase">报价金额</th><th class="px-4 py-3 text-left text-xs font-medium text-gray-400 uppercase">状态</th><th class="px-4 py-3 text-left text-xs font-medium text-gray-400 uppercase">时间</th></tr></thead><tbody style="border-top-width: 1px; border-top-color: rgba(55, 65, 81, 1);">' + quoteRows + '</tbody></table></div><div class="mt-4 pt-4 border-t border-gray-700 flex justify-between"><span class="text-gray-400">总报价金额：<span class="text-amber-400 font-bold">¥' + quotes.reduce(function(sum, q) { return sum + (q.quote_amount || 0); }, 0).toLocaleString() + '</span></span><button id="closeQuoteBtn" class="btn btn-secondary btn-sm">关闭</button></div>';
        
        document.getElementById('quoteModal').classList.add('active');
        
        document.getElementById('closeQuoteBtn').addEventListener('click', closeQuoteModal);
      }

      function closeQuoteModal() {
        document.getElementById('quoteModal').classList.remove('active');
      }

      function closeOrderDetailModal() {
        document.getElementById('orderDetailModal').classList.remove('active');
      }

      function viewOrderDetails(orderId) {
        const order = allOrders.find(function(o) { return o.id === orderId; });
        const sales = salesTeam.find(function(s) { return s.id === (order ? order.assigned_sales_id : null); });
        if (!order) return;

        const content = document.getElementById('orderDetailContent');
        content.innerHTML = '<div class="space-y-4"><div class="grid grid-cols-2 gap-4"><div><p class="text-gray-400 text-sm">订单号</p><p class="text-white font-mono">' + order.id + '</p></div><div><p class="text-gray-400 text-sm">客户邮箱</p><p class="text-white">' + order.customer_email + '</p></div><div><p class="text-gray-400 text-sm">负责业务员</p><p class="text-white">' + (sales ? sales.name : '未分配') + '</p></div><div><p class="text-gray-400 text-sm">负责区域</p><p class="text-white">' + (regionLabels[order.region] || order.region) + '</p></div><div><p class="text-gray-400 text-sm">报价金额</p><p class="text-amber-400 text-xl font-bold">¥' + (order.quote_amount ? order.quote_amount.toLocaleString() : '待报价') + '</p></div><div><p class="text-gray-400 text-sm">订单状态</p><p class="text-white"><span class="badge ' + statusColors[order.status] + '">' + statusLabels[order.status] + '</span></p></div><div><p class="text-gray-400 text-sm">创建时间</p><p class="text-white">' + new Date(order.created_at).toLocaleString('zh-CN') + '</p></div></div>' + (sales ? '<div class="mt-4 pt-4 border-t border-gray-700"><p class="text-gray-400 text-sm mb-2">业务员联系方式</p><p class="text-white">邮箱: ' + sales.email + '</p><p class="text-white">手机: ' + (sales.phone || '-') + '</p><p class="text-white">微信: ' + (sales.wechat || '-') + '</p></div>' : '') + '<div class="mt-4 pt-4 border-t border-gray-700 flex justify-end"><button id="closeOrderDetailBtn" class="btn btn-secondary">关闭</button></div></div>';

        document.getElementById('orderDetailModal').classList.add('active');
        document.getElementById('closeOrderDetailBtn').addEventListener('click', closeOrderDetailModal);
      }

      function viewOrderQuote(orderId) {
        const order = allOrders.find(function(o) { return o.id === orderId; });
        const sales = salesTeam.find(function(s) { return s.id === (order ? order.assigned_sales_id : null); });
        if (!order) return;

        const bomItems = [
          { part_number: 'STM32F407VGT6', manufacturer: 'STMicroelectronics', quantity: 100, unit_price: 85.50, lead_time: '4-6 weeks' },
          { part_number: 'TPS65988DHP', manufacturer: 'Texas Instruments', quantity: 50, unit_price: 128.00, lead_time: '6-8 weeks' },
          { part_number: 'MT41K256M16HA-125', manufacturer: 'Micron', quantity: 200, unit_price: 12.30, lead_time: '2-3 weeks' },
          { part_number: 'ESP32-WROOM-32', manufacturer: 'Espressif', quantity: 150, unit_price: 3.20, lead_time: '1-2 weeks' },
          { part_number: 'USB4105-GF-A', manufacturer: 'GCT', quantity: 300, unit_price: 2.80, lead_time: '3-4 weeks' }
        ];

        let bomRows = bomItems.map(function(item) {
          return '<tr><td class="px-4 py-3 text-sm text-gray-300 font-mono">' + item.part_number + '</td><td class="px-4 py-3 text-sm text-gray-300">' + item.manufacturer + '</td><td class="px-4 py-3 text-sm text-gray-300 text-right">' + item.quantity + '</td><td class="px-4 py-3 text-sm text-gray-300 text-right">$' + item.unit_price.toFixed(2) + '</td><td class="px-4 py-3 text-sm text-gray-300 text-right">¥' + (item.unit_price * 7.2 * 1.15).toFixed(2) + '</td><td class="px-4 py-3 text-sm text-gray-300">' + item.lead_time + '</td></tr>';
        }).join('');

        const content = document.getElementById('orderDetailContent');
        content.innerHTML = '<div class="mb-4"><div class="flex justify-between items-center"><h4 class="text-white font-medium">BOM 物料清单</h4><span class="badge ' + statusColors[order.status] + '">' + statusLabels[order.status] + '</span></div></div><div class="overflow-x-auto"><table class="w-full"><thead><tr style="background-color: rgba(55, 65, 81, 0.5);"><th class="px-4 py-3 text-left text-xs font-medium text-gray-400 uppercase">型号</th><th class="px-4 py-3 text-left text-xs font-medium text-gray-400 uppercase">品牌</th><th class="px-4 py-3 text-right text-xs font-medium text-gray-400 uppercase">数量</th><th class="px-4 py-3 text-right text-xs font-medium text-gray-400 uppercase">单价(USD)</th><th class="px-4 py-3 text-right text-xs font-medium text-gray-400 uppercase">报价(RMB)</th><th class="px-4 py-3 text-left text-xs font-medium text-gray-400 uppercase">货期</th></tr></thead><tbody style="border-top-width: 1px; border-top-color: rgba(55, 65, 81, 1);">' + bomRows + '</tbody></table></div><div class="mt-4 pt-4 border-t border-gray-700"><div class="flex justify-between items-center"><div><p class="text-gray-400">订单信息</p><p class="text-white">客户: ' + order.customer_email + '</p><p class="text-white">业务员: ' + (sales ? sales.name : '未分配') + '</p></div><div class="text-right"><p class="text-gray-400">总计</p><p class="text-3xl font-bold text-amber-400">¥' + (order.quote_amount ? order.quote_amount.toLocaleString() : '待报价') + '</p></div></div></div><div class="mt-4 pt-4 border-t border-gray-700 flex justify-end gap-2"><button id="printQuoteBtn" class="btn btn-secondary">打印报价单</button><button id="closeOrderQuoteBtn" class="btn btn-primary">关闭</button></div></div>';

        document.getElementById('orderDetailModal').classList.add('active');
        document.getElementById('closeOrderQuoteBtn').addEventListener('click', closeOrderDetailModal);
      }

      function approveAccount(id) {
        const approval = pendingApprovals.find(function(p) { return p.id === id; });
        if (!approval) return;
        salesTeam.push({
          id: 'sales-' + Date.now(),
          name: approval.name,
          email: approval.email,
          phone: approval.phone,
          wechat: '',
          region: 'CN',
          performance_total: 0,
          status: 'active'
        });
        pendingApprovals = pendingApprovals.filter(function(p) { return p.id !== id; });
        renderApprovalTable();
        renderSalesTable();
        renderDashboard();
        alert('账号 ' + approval.name + ' 已通过审批');
      }

      function rejectAccount(id) {
        if (!confirm('确定要拒绝该账号申请吗？')) return;
        pendingApprovals = pendingApprovals.filter(function(p) { return p.id !== id; });
        renderApprovalTable();
        renderDashboard();
        alert('已拒绝该账号申请');
      }

      function handlePasswordChange(e) {
        e.preventDefault();
        const current = document.getElementById('currentPassword').value;
        const newPwd = document.getElementById('newPassword').value;
        const confirm = document.getElementById('confirmPassword').value;

        if (newPwd !== confirm) {
          alert('两次输入的新密码不一致');
          return;
        }
        if (newPwd.length < 6) {
          alert('新密码长度不能少于6位');
          return;
        }
        if (current !== 'Yiyi0058') {
          alert('当前密码错误');
          return;
        }
        alert('密码修改成功');
        document.getElementById('passwordForm').reset();
      }

      function openAccountModal() {
        document.getElementById('accountForm').reset();
        document.getElementById('accountModal').classList.add('active');
      }

      function closeAccountModal() {
        document.getElementById('accountModal').classList.remove('active');
      }

      function handleAccountSubmit(e) {
        e.preventDefault();
        const name = document.getElementById('accountName').value;
        const email = document.getElementById('accountEmail').value;
        const phone = document.getElementById('accountPhone').value;
        const region = document.getElementById('accountRegion').value;
        const password = document.getElementById('accountPassword').value;

        pendingApprovals.push({
          id: 'app-' + Date.now(),
          name: name,
          email: email,
          phone: phone,
          appliedAt: new Date(),
          password: password || '123456'
        });

        closeAccountModal();
        renderApprovalTable();
        renderDashboard();
        alert('账号申请已添加，等待审批');
      }

      function updateTime() {
        document.getElementById('currentTime').textContent = new Date().toLocaleString('zh-CN');
      }

      document.addEventListener('DOMContentLoaded', function() {
        const userData = localStorage.getItem('currentUser');
        if (userData) {
          try {
            const user = JSON.parse(userData);
            document.getElementById('userName').textContent = user.name || '管理员';
            document.getElementById('userRole').textContent = user.role === 'admin' ? '系统管理员' : (user.role === 'sales' ? '业务员' : '客户');
            document.getElementById('userAvatar').textContent = (user.name || 'A').charAt(0).toUpperCase();
          } catch (e) {
            console.error('Failed to parse user data', e);
          }
        }
        
        document.getElementById('nav-dashboard').addEventListener('click', function() { showSection('dashboard'); });
        document.getElementById('nav-sales').addEventListener('click', function() { showSection('sales'); });
        document.getElementById('nav-approval').addEventListener('click', function() { showSection('approval'); });
        document.getElementById('nav-blog-review').addEventListener('click', function() { showSection('blog-review'); renderBlogReviewTable(); });
        document.getElementById('nav-create-post').addEventListener('click', function() { window.location.href = '/dashboard/create-post'; });
        document.getElementById('nav-orders').addEventListener('click', function() { showSection('orders'); });
        document.getElementById('nav-settings').addEventListener('click', function() { showSection('settings'); });
        
        document.getElementById('logoutBtn').addEventListener('click', function() {
          localStorage.removeItem('currentUser');
          window.location.href = '/login';
        });
        
        document.getElementById('addSalesBtn').addEventListener('click', openAddSalesModal);
        document.getElementById('closeSalesModalBtn').addEventListener('click', closeSalesModal);
        document.getElementById('cancelSalesModalBtn').addEventListener('click', closeSalesModal);
        document.getElementById('closeQuoteModalBtn').addEventListener('click', closeQuoteModal);
        
        document.getElementById('salesForm').addEventListener('submit', handleSalesSubmit);
        document.getElementById('passwordForm').addEventListener('submit', handlePasswordChange);
        document.getElementById('accountForm').addEventListener('submit', handleAccountSubmit);

        document.getElementById('addAccountBtn').addEventListener('click', openAccountModal);
        document.getElementById('closeAccountModalBtn').addEventListener('click', closeAccountModal);
        document.getElementById('cancelAccountModalBtn').addEventListener('click', closeAccountModal);

        document.getElementById('salesTable').addEventListener('click', function(e) {
          const btn = e.target.closest('button');
          if (!btn) return;
          const action = btn.getAttribute('data-action');
          const id = btn.getAttribute('data-id');
          if (action === 'view-quote') viewSalesQuotes(id);
          else if (action === 'edit-sales') editSales(id);
          else if (action === 'delete-sales') deleteSales(id);
        });

        document.getElementById('approvalTable').addEventListener('click', function(e) {
          const btn = e.target.closest('button');
          if (!btn) return;
          const action = btn.getAttribute('data-action');
          const id = btn.getAttribute('data-id');
          if (action === 'approve') approveAccount(id);
          else if (action === 'reject') rejectAccount(id);
        });

        document.getElementById('ordersTable').addEventListener('click', function(e) {
          const btn = e.target.closest('button');
          if (!btn) return;
          const action = btn.getAttribute('data-action');
          const id = btn.getAttribute('data-id');
          if (action === 'view-order-detail') viewOrderDetails(id);
          else if (action === 'view-order-quote') viewOrderQuote(id);
        });

        document.getElementById('closeOrderDetailModalBtn').addEventListener('click', closeOrderDetailModal);
        document.getElementById('closeBlogDetailModalBtn').addEventListener('click', closeBlogDetailModal);

        document.getElementById('blogReviewTable').addEventListener('click', function(e) {
          const btn = e.target.closest('button');
          if (!btn) return;
          const action = btn.getAttribute('data-action');
          const id = btn.getAttribute('data-id');
          const blog = pendingBlogs.find(function(b) { return b.id === id; });
          if (action === 'view-blog-detail' && blog) openBlogDetail(blog);
          else if (action === 'approve-blog') approveBlog(id);
          else if (action === 'reject-blog') rejectBlog(id);
        });

        renderDashboard();
        renderSalesTable();
        renderApprovalTable();
        renderOrdersTable();
        loadPendingBlogs();
        updateTime();
        setInterval(updateTime, 1000);
      });
    </script>
</body>
</html>