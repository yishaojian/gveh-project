                <div class="flex items-center gap-2 mb-2">
                  <span class="text-xs bg-red-500/20 text-red-400 px-2 py-1 rounded">中文</span>
                  <span class="text-xs text-gray-500">CN</span>
                </div>
                <h4 class="text-lg font-semibold text-white mb-2">${blog.title_cn || '无标题'}</h4>
                <div class="text-sm text-gray-300 whitespace-pre-wrap max-h-96 overflow-y-auto leading-relaxed">${blog.content_cn || '无内容'}</div>
              </div>

              <div class="bg-gray-800/50 rounded-lg p-4 border border-gray-700">
                <div class="flex items-center gap-2 mb-2">
                  <span class="text-xs bg-blue-500/20 text-blue-400 px-2 py-1 rounded">English</span>
                  <span class="text-xs text-gray-500">EN</span>
