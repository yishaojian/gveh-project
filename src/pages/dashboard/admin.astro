                <h4 class="text-lg font-semibold text-white mb-2">${blog.title_en || 'No Title'}</h4>
                <div class="text-sm text-gray-300 whitespace-pre-wrap max-h-96 overflow-y-auto leading-relaxed">${blog.content_en || 'No Content'}</div>
              </div>
            </div>

            <div class="bg-gradient-to-r from-purple-900/20 to-purple-700/20 rounded-lg p-4 border border-purple-500/30">
              <h4 class="text-sm font-medium text-purple-400 mb-3 flex items-center gap-2">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 00.95.69h4.915c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 00-.363 1.118l1.518 4.674c.3.922-.755 1.688-1.538 1.118l-3.976-2.888a1 1 0 00-1.176 0l-3.976 2.888c-.783.57-1.838-.197-1.538-1.118l1.518-4.674a1 1 0 00-.363-1.118l-3.976-2.888c-.784-.57-.38-1.81.588-1.81h4.914a1 1 0 00.951-.69l1.519-4.674z"/></svg>
                SEO 关键词（AI自动生成）
              </h4>
              <div class="flex flex-wrap gap-2">
                ${(blog.keywords || '').split(',').map(function(k) { return '<span class="px-3 py-1 bg-purple-500/20 text-purple-300 text-xs rounded-full">' + k.trim() + '</span>'; }).join('')}
              </div>
            </div>

            <div class="flex items-center justify-between text-sm text-gray-400 pt-4 border-t border-gray-700">
              <span>提交时间: ${new Date(blog.created_at).toLocaleString('zh-CN')}</span>
              <span>作者: ${blog.author_name || '未知'}</span>
            </div>

            <div class="flex gap-3 pt-4">
              <button class="btn btn-success flex-1 flex items-center justify-center gap-2" onclick="approveBlog('${blog.id}'); closeBlogDetailModal();">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
                审核通过（一键上线）
              </button>
              <button class="btn btn-danger flex-1 flex items-center justify-center gap-2" onclick="rejectBlog('${blog.id}'); closeBlogDetailModal();">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
