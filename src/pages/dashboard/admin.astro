    <script>
      let salesTeam = [
        { id: 'sales-001', name: '张伟', email: 'zhangwei@pnds.com', phone: '13800138001', wechat: 'zhangwei_cn', region: 'CN', performance_total: 1560000, status: 'active' },
        { id: 'sales-002', name: '王芳', email: 'wangfang@pnds.com', phone: '13800138002', wechat: 'wangfang_eu', region: 'EU', performance_total: 1890000, status: 'active' },
        { id: 'sales-003', name: '李明', email: 'liming@pnds.com', phone: '13800138003', wechat: 'liming_global', region: 'Global', performance_total: 2200000, status: 'active' }
      ];

      let pendingApprovals = [
        { id: 'app-001', name: '陈静', email: 'chenjing@pnds.com', phone: '13800138004', appliedAt: new Date(Date.now() - 86400000) },
        { id: 'app-002', name: '刘洋', email: 'liuyang@pnds.com', phone: '13800138005', appliedAt: new Date(Date.now() - 172800000) }
      ];

      let allOrders = [
        { id: 'bom-001', customer_email: 'procurement@huawei.cn', assigned_sales_id: 'sales-001', region: 'CN', quote_amount: 258000, status: 'pending', created_at: new Date(Date.now() - 3600000) },
        { id: 'bom-002', customer_email: 'buyer@siemens.de', assigned_sales_id: 'sales-002', region: 'EU', quote_amount: 385000, status: 'quoted', created_at: new Date(Date.now() - 7200000) },
        { id: 'bom-003', customer_email: 'purchasing@apple.com', assigned_sales_id: 'sales-003', region: 'US', quote_amount: 520000, status: 'ordered', created_at: new Date(Date.now() - 10800000) },
        { id: 'bom-004', customer_email: 'parts@sony.jp', assigned_sales_id: 'sales-003', region: 'APAC', quote_amount: 186000, status: 'completed', created_at: new Date(Date.now() - 86400000) },
        { id: 'bom-005', customer_email: 'component@xiaomi.com', assigned_sales_id: 'sales-001', region: 'CN', quote_amount: 420000, status: 'pending', created_at: new Date(Date.now() - 14400000) },
        { id: 'bom-006', customer_email: 'tech@samsung.com', assigned_sales_id: 'sales-003', region: 'APAC', quote_amount: 680000, status: 'quoted', created_at: new Date(Date.now() - 21600000) },
        { id: 'bom-007', customer_email: 'electronics@bosch.de', assigned_sales_id: 'sales-002', region: 'EU', quote_amount: 315000, status: 'ordered', created_at: new Date(Date.now() - 28800000) },
        { id: 'bom-008', customer_email: 'hardware@intel.com', assigned_sales_id: 'sales-003', region: 'US', quote_amount: 750000, status: 'completed', created_at: new Date(Date.now() - 43200000) }
      ];

      let pendingBlogs = [];

      const statusLabels = { pending: '待报价', quoted: '已报价', ordered: '已下单', completed: '已完成', cancelled: '已取消' };
      const statusColors = { pending: 'badge-warning', quoted: 'badge-info', ordered: 'badge-purple', completed: 'badge-success', cancelled: 'badge-danger' };
      const regionLabels = { CN: '中国大陆', EU: '欧洲', US: '美洲', APAC: '亚太', Global: '全球' };

      function showSection(sectionName) {
        document.querySelectorAll('[id^="section-"]').forEach(function(s) {
          s.classList.add('hidden');
        });
        document.querySelectorAll('nav button').forEach(function(btn) {
          btn.classList.remove('active-nav');
          btn.classList.add('default-nav');
        });
        
        document.getElementById('section-' + sectionName).classList.remove('hidden');
        document.getElementById('nav-' + sectionName).classList.add('active-nav');
        document.getElementById('nav-' + sectionName).classList.remove('default-nav');
      }

      function renderDashboard() {
        const pendingOrders = allOrders.filter(function(o) { return o.status === 'pending'; }).length;
        const totalRevenue = salesTeam.reduce(function(sum, s) { return sum + (s.performance_total || 0); }, 0);
        
        document.getElementById('pendingOrderCount').textContent = pendingOrders;
        document.getElementById('salesTeamCount').textContent = salesTeam.length;
        document.getElementById('pendingApprovalCount').textContent = pendingApprovals.length;
        document.getElementById('totalRevenue').textContent = '¥' + totalRevenue.toLocaleString();
        document.getElementById('pendingBadge').textContent = pendingApprovals.length;

        const tbody = document.getElementById('dashboardOrderTable');
        tbody.innerHTML = '';
        allOrders.slice(0, 5).forEach(function(order) {
          const sales = salesTeam.find(function(s) { return s.id === order.assigned_sales_id; });
          tbody.innerHTML += '<tr class="hover-tr"><td class="px-6 py-4 whitespace-nowrap"><span class="text-sm text-gray-300 font-mono">' + order.id + '</span></td><td class="px-6 py-4 whitespace-nowrap"><span class="text-sm text-gray-300">' + order.customer_email + '</span></td><td class="px-6 py-4 whitespace-nowrap"><span class="text-sm text-gray-300">' + (sales ? sales.name : '未分配') + '</span></td><td class="px-6 py-4 whitespace-nowrap"><span class="text-sm text-gray-300">' + (regionLabels[order.region] || '-') + '</span></td><td class="px-6 py-4 whitespace-nowrap"><span class="badge ' + statusColors[order.status] + '">' + statusLabels[order.status] + '</span></td><td class="px-6 py-4 whitespace-nowrap"><span class="text-sm text-gray-400">' + new Date(order.created_at).toLocaleString('zh-CN') + '</span></td></tr>';
        });
      }

      function renderSalesTable() {
        const tbody = document.getElementById('salesTable');
        tbody.innerHTML = '';
        salesTeam.forEach(function(sales) {
          tbody.innerHTML += '<tr class="hover-tr"><td class="px-6 py-4 whitespace-nowrap"><span class="text-sm text-gray-300">' + sales.name + '</span></td><td class="px-6 py-4 whitespace-nowrap"><span class="text-sm text-gray-300">' + sales.email + '</span></td><td class="px-6 py-4 whitespace-nowrap"><span class="text-sm text-gray-300">' + (sales.phone || '-') + '</span></td><td class="px-6 py-4 whitespace-nowrap"><span class="text-sm text-gray-300">' + (sales.wechat || '-') + '</span></td><td class="px-6 py-4 whitespace-nowrap"><span class="badge badge-info">' + (regionLabels[sales.region] || sales.region) + '</span></td><td class="px-6 py-4 whitespace-nowrap"><span class="text-sm text-gray-300">¥' + sales.performance_total.toLocaleString() + '</span></td><td class="px-6 py-4 whitespace-nowrap"><span class="badge badge-success">在职</span></td><td class="px-6 py-4 whitespace-nowrap"><div class="flex gap-2"><button class="icon-btn" data-action="view-quote" data-id="' + sales.id + '" title="查看报价"><svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/></svg></button><button class="icon-btn" data-action="edit-sales" data-id="' + sales.id + '" title="编辑"><svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/></svg></button><button class="icon-btn" data-action="delete-sales" data-id="' + sales.id + '" title="删除" style="color: #f87171;"><svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/></svg></button></div></td></tr>';
        });
      }

      function renderApprovalTable() {
        const tbody = document.getElementById('approvalTable');
        if (pendingApprovals.length === 0) {
          tbody.innerHTML = '<tr><td colspan="6" class="px-6 py-12 text-center text-gray-400">暂无待审批的账号</td></tr>';
          return;
        }
        tbody.innerHTML = '';
        pendingApprovals.forEach(function(p) {
          tbody.innerHTML += '<tr class="hover-tr"><td class="px-6 py-4 whitespace-nowrap"><span class="text-sm text-gray-300">' + p.name + '</span></td><td class="px-6 py-4 whitespace-nowrap"><span class="text-sm text-gray-300">' + p.email + '</span></td><td class="px-6 py-4 whitespace-nowrap"><span class="text-sm text-gray-300">' + p.phone + '</span></td><td class="px-6 py-4 whitespace-nowrap"><span class="text-sm text-gray-400">' + new Date(p.appliedAt).toLocaleString('zh-CN') + '</span></td><td class="px-6 py-4 whitespace-nowrap"><span class="badge badge-warning">待审批</span></td><td class="px-6 py-4 whitespace-nowrap"><div class="flex gap-2"><button class="btn btn-success btn-sm" data-action="approve" data-id="' + p.id + '">通过</button><button class="btn btn-danger btn-sm" data-action="reject" data-id="' + p.id + '">拒绝</button></div></td></tr>';
        });
      }

      function renderOrdersTable() {
        const tbody = document.getElementById('ordersTable');
        tbody.innerHTML = '';
        allOrders.forEach(function(order) {
          const sales = salesTeam.find(function(s) { return s.id === order.assigned_sales_id; });
          tbody.innerHTML += '<tr class="hover-tr"><td class="px-6 py-4 whitespace-nowrap"><span class="text-sm text-gray-300 font-mono">' + order.id + '</span></td><td class="px-6 py-4 whitespace-nowrap"><span class="text-sm text-gray-300">' + order.customer_email + '</span></td><td class="px-6 py-4 whitespace-nowrap"><span class="text-sm text-gray-300">' + (sales ? sales.name : '未分配') + '</span></td><td class="px-6 py-4 whitespace-nowrap"><span class="badge badge-info">' + (regionLabels[order.region] || order.region) + '</span></td><td class="px-6 py-4 whitespace-nowrap"><span class="text-sm text-gray-300">¥' + (order.quote_amount ? order.quote_amount.toLocaleString() : '-') + '</span></td><td class="px-6 py-4 whitespace-nowrap"><span class="badge ' + statusColors[order.status] + '">' + statusLabels[order.status] + '</span></td><td class="px-6 py-4 whitespace-nowrap"><span class="text-sm text-gray-400">' + new Date(order.created_at).toLocaleString('zh-CN') + '</span></td><td class="px-6 py-4 whitespace-nowrap"><div class="flex gap-2"><button class="btn btn-secondary btn-sm" data-action="view-order-detail" data-id="' + order.id + '">详情</button><button class="btn btn-primary btn-sm" data-action="view-order-quote" data-id="' + order.id + '">报价</button></div></td></tr>';
        });
      }

      async function loadPendingBlogs() {
        try {
          const response = await fetch('/api/blog/pending');
          const data = await response.json();
          pendingBlogs = data.blogs || [];
          document.getElementById('blogPendingBadge').textContent = pendingBlogs.length;
        } catch (error) {
          console.error('加载待审核博客失败:', error);
          pendingBlogs = [];
        }
      }

      function renderBlogReviewTable() {
        const tbody = document.getElementById('blogReviewTable');
        if (pendingBlogs.length === 0) {
          tbody.innerHTML = '<tr><td colspan="5" class="px-6 py-12 text-center text-gray-400">暂无待审核的博客</td></tr>';
          return;
        }
        tbody.innerHTML = '';
        pendingBlogs.forEach(function(blog) {
          const title = blog.title_cn || blog.title_en || '无标题';
          const keywords = blog.keywords || '无关键词';
          const authorName = blog.author_name || '未知作者';
          tbody.innerHTML += '<tr class="hover-tr"><td class="px-6 py-4 whitespace-nowrap"><span class="text-sm text-gray-300">' + title + '</span></td><td class="px-6 py-4 whitespace-nowrap"><span class="text-sm text-gray-300">' + authorName + '</span></td><td class="px-6 py-4 whitespace-nowrap"><span class="text-sm text-gray-300">' + keywords + '</span></td><td class="px-6 py-4 whitespace-nowrap"><span class="text-sm text-gray-400">' + new Date(blog.created_at).toLocaleString('zh-CN') + '</span></td><td class="px-6 py-4 whitespace-nowrap"><div class="flex gap-2"><button class="btn btn-secondary btn-sm" data-action="view-blog-detail" data-id="' + blog.id + '">查看</button><button class="btn btn-success btn-sm" data-action="approve-blog" data-id="' + blog.id + '">通过</button><button class="btn btn-danger btn-sm" data-action="reject-blog" data-id="' + blog.id + '">拒绝</button></div></td></tr>';
        });
      }

      async function approveBlog(blogId) {
        try {
          const response = await fetch('/api/blog/review', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ blog_id: blogId, action: 'approve' })
          });
          if (response.ok) {
            await loadPendingBlogs();
            renderBlogReviewTable();
          } else {
            alert('审核失败');
          }
        } catch (error) {
          console.error('审核博客失败:', error);
          alert('审核失败');
        }
      }

      async function rejectBlog(blogId) {
        try {
          const response = await fetch('/api/blog/review', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ blog_id: blogId, action: 'reject' })
          });
          if (response.ok) {
            await loadPendingBlogs();
            renderBlogReviewTable();
          } else {
            alert('拒绝失败');
          }
        } catch (error) {
          console.error('拒绝博客失败:', error);
          alert('拒绝失败');
        }
      }

      function openBlogDetail(blog) {
        const content = `
          <div class="space-y-6">
            <div class="flex items-center gap-2 mb-4">
              <span class="badge badge-warning">待审核</span>
              <span class="text-xs text-gray-400">AI 自动翻译完成</span>
            </div>
            
            <div class="border-b border-gray-700 pb-4">
              <h4 class="text-sm font-medium text-gray-400 mb-3 flex items-center gap-2">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"/></svg>
