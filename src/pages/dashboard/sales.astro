<body>
  <div class="min-h-screen bg-gray-900">
    <div class="fixed left-0 top-0 h-screen w-64 bg-gray-800 border-r border-gray-700">
      <div class="p-6">
        <div class="flex items-center space-x-3">
          <div class="w-10 h-10 bg-gradient-to-r rounded-lg flex items-center justify-center">
            <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"/>
            </svg>
          </div>
          <div>
            <h1 class="text-lg font-bold text-white">PNDS Hub</h1>
            <p class="text-xs text-gray-400">销售员工作台</p>
          </div>
        </div>
      </div>
      
      <nav class="p-4 space-y-2">
        <button id="nav-orders" class="w-full px-4 py-3 active-nav rounded-lg font-medium flex items-center space-x-3 transition-colors cursor-pointer">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 0 012 2m-3 7h3m-3 4h3m-6-4h.01M9 16h.01"/></svg>
          <span>我的订单</span>
        </button>
        <button id="nav-posts" class="w-full px-4 py-3 default-nav hover-bg-gray-700 rounded-lg font-medium flex items-center space-x-3 transition-colors cursor-pointer">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/></svg>
          <span>发布文章</span>
        </button>
        <button id="nav-profile" class="w-full px-4 py-3 default-nav hover-bg-gray-700 rounded-lg font-medium flex items-center space-x-3 transition-colors cursor-pointer">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/></svg>
          <span>个人资料</span>
        </button>
        <button id="nav-password" class="w-full px-4 py-3 default-nav hover-bg-gray-700 rounded-lg font-medium flex items-center space-x-3 transition-colors cursor-pointer">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 7a2 2 0 012 2m4 0a6 6 0 01-7.743 5.743L11 17H9v2H7v2H4a1 1 0 01-1-1v-2.586a1 1 0 01.293-.707l5.964-5.964A6 6 0 1121 9z"/></svg>
          <span>修改密码</span>
        </button>
      </nav>
      
      <div class="absolute bottom-0 left-0 right-0 p-4 border-t border-gray-700">
        <button id="logoutBtn" class="w-full px-4 py-3 text-gray-400 hover:text-white hover-bg-gray-700 rounded-lg font-medium flex items-center space-x-3 transition-colors cursor-pointer">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1"/></svg>
          <span>退出登录</span>
        </button>
      </div>
    </div>

    <div class="header-bar">
      <div class="user-info">
        <div class="user-details">
          <div class="user-name" id="userName">销售员</div>
          <div class="user-role" id="userRole">普通业务员</div>
        </div>
        <div class="user-avatar" id="userAvatar">S</div>
      </div>
    </div>

    <div class="ml-64 p-8 content-area">
      <div id="section-orders">
        <div class="flex items-center justify-between mb-8">
          <div>
            <h2 class="text-2xl font-bold text-white">我的订单</h2>
            <p class="text-gray-400 mt-1" id="welcomeMsg">欢迎回来，销售员</p>
          </div>
          <div class="text-right">
            <p class="text-gray-400 text-sm">我的业绩</p>
            <p class="text-2xl font-bold text-amber-400" id="performance">¥0</p>
          </div>
        </div>

        <div class="grid grid-cols-2 gap-6 mb-8">
          <div class="bg-gray-800 rounded-xl p-6 border border-gray-700">
            <div class="flex items-center justify-between">
              <div>
                <p class="text-gray-400 text-sm">待处理订单</p>
                <p class="text-3xl font-bold text-white mt-2" id="pendingCount">0</p>
              </div>
              <div class="w-12 h-12 bg-yellow-500-20 rounded-lg flex items-center justify-center">
                <svg class="w-6 h-6 text-yellow-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
              </div>
            </div>
          </div>
          <div class="bg-gray-800 rounded-xl p-6 border border-gray-700">
            <div class="flex items-center justify-between">
              <div>
                <p class="text-gray-400 text-sm">已完成订单</p>
                <p class="text-3xl font-bold text-white mt-2" id="completedCount">0</p>
              </div>
              <div class="w-12 h-12 bg-green-500-20 rounded-lg flex items-center justify-center">
                <svg class="w-6 h-6 text-green-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
              </div>
            </div>
          </div>
        </div>

        <div class="bg-gray-800 rounded-xl border border-gray-700 overflow-hidden">
          <div class="overflow-x-auto">
            <table class="w-full">
              <thead class="bg-gray-700/50">
                <tr>
                  <th class="px-6 py-4 text-left text-xs font-medium text-gray-400 uppercase tracking-wider">订单号</th>
                  <th class="px-6 py-4 text-left text-xs font-medium text-gray-400 uppercase tracking-wider">客户邮箱</th>
                  <th class="px-6 py-4 text-left text-xs font-medium text-gray-400 uppercase tracking-wider">区域</th>
                  <th class="px-6 py-4 text-left text-xs font-medium text-gray-400 uppercase tracking-wider">报价金额</th>
                  <th class="px-6 py-4 text-left text-xs font-medium text-gray-400 uppercase tracking-wider">状态</th>
                  <th class="px-6 py-4 text-left text-xs font-medium text-gray-400 uppercase tracking-wider">提交时间</th>
                  <th class="px-6 py-4 text-left text-xs font-medium text-gray-400 uppercase tracking-wider">操作</th>
                </tr>
              </thead>
              <tbody class="divide-y divide-gray-700" id="orderTableBody">
              </tbody>
            </table>
          </div>
        </div>
      </div>

      <div id="section-profile" class="hidden">
        <div class="mb-8">
          <h2 class="text-2xl font-bold text-white">个人资料</h2>
          <p class="text-gray-400 mt-1">查看和修改您的个人信息</p>
        </div>

        <div class="bg-gray-800 rounded-xl border border-gray-700 p-6 max-w-md">
          <form id="profileForm">
            <div class="form-group">
              <label class="form-label">姓名</label>
              <input type="text" class="form-input" id="profileName" placeholder="请输入姓名" />
            </div>
            <div class="form-group">
              <label class="form-label">邮箱</label>
              <input type="email" class="form-input" id="profileEmail" placeholder="请输入邮箱" />
            </div>
            <div class="form-group">
              <label class="form-label">手机号</label>
              <input type="tel" class="form-input" id="profilePhone" placeholder="请输入手机号" />
            </div>
            <div class="form-group">
              <label class="form-label">微信号</label>
              <input type="text" class="form-input" id="profileWechat" placeholder="请输入微信号" />
            </div>
            <div class="form-group">
              <label class="form-label">负责区域</label>
              <input type="text" class="form-input" id="profileRegion" disabled />
            </div>
            <div class="flex gap-2 mt-4">
              <button type="submit" class="btn btn-primary flex-1">保存修改</button>
              <button type="button" class="btn btn-secondary flex-1" onclick="document.getElementById('profileForm').reset()">重置</button>
            </div>
          </form>
        </div>
      </div>

      <div id="section-password" class="hidden">
        <div class="mb-8">
          <h2 class="text-2xl font-bold text-white">修改密码</h2>
          <p class="text-gray-400 mt-1">修改您的登录密码</p>
        </div>

        <div class="bg-gray-800 rounded-xl border border-gray-700 p-6 max-w-md">
          <form id="passwordForm">
            <div class="form-group">
              <label class="form-label">当前密码 *</label>
              <input type="password" class="form-input" id="currentPassword" required placeholder="请输入当前密码" />
            </div>
            <div class="form-group">
              <label class="form-label">新密码 *</label>
              <input type="password" class="form-input" id="newPassword" required placeholder="请输入新密码" />
            </div>
            <div class="form-group">
              <label class="form-label">确认密码 *</label>
              <input type="password" class="form-input" id="confirmPassword" required placeholder="请再次输入新密码" />
            </div>
            <div class="flex gap-2 mt-4">
              <button type="submit" class="btn btn-primary flex-1">修改密码</button>
              <button type="button" class="btn btn-secondary flex-1" onclick="document.getElementById('passwordForm').reset()">重置</button>
            </div>
          </form>
        </div>
      </div>
    </div>

    <div id="quoteModal" class="modal-overlay">
      <div class="modal-content" style="max-width: 700px;">
        <div class="modal-header">
          <h3 class="modal-title">订单报价详情</h3>
          <button id="closeQuoteModalBtn" class="close-btn">&times;</button>
        </div>
        <div id="quoteDetails"></div>
      </div>
    </div>

    <script>
      const regionLabels = { CN: '中国大陆', EU: '欧洲', US: '美洲', APAC: '亚太', Global: '全球' };
      const statusLabels = { pending: '待报价', quoted: '已报价', ordered: '已下单', completed: '已完成', cancelled: '已取消' };
      const statusColors = { pending: 'badge-warning', quoted: 'badge-info', ordered: 'badge-purple', completed: 'badge-success', cancelled: 'badge-danger' };

      const currentUser = {
        id: 'sales-001',
        name: '张伟',
        email: 'zhangwei@pnds.com',
        phone: '13800138001',
        wechat: 'zhangwei_cn',
        region: 'CN',
        performance_total: 1560000
      };

      const myOrders = [
        { id: 'bom-001', customer_email: 'procurement@huawei.cn', region: 'CN', quote_amount: 258000, status: 'pending', created_at: new Date(Date.now() - 3600000) },
        { id: 'bom-005', customer_email: 'component@xiaomi.com', region: 'CN', quote_amount: 420000, status: 'pending', created_at: new Date(Date.now() - 14400000) }
      ];

      function showSection(sectionName) {
        document.querySelectorAll('[id^="section-"]').forEach(function(s) {
          s.classList.add('hidden');
        });
        document.querySelectorAll('nav button').forEach(function(btn) {
          btn.classList.remove('active-nav');
          btn.classList.add('default-nav');
        });
        document.getElementById('section-' + sectionName).classList.remove('hidden');
        document.getElementById('nav-' + sectionName).classList.add('active-nav');
        document.getElementById('nav-' + sectionName).classList.remove('default-nav');
      }

      function renderOrders() {
        const tbody = document.getElementById('orderTableBody');
        if (myOrders.length === 0) {
          tbody.innerHTML = '<tr><td colspan="7" class="px-6 py-12 text-center text-gray-400">暂无分配给您的订单</td></tr>';
          return;
        }
        tbody.innerHTML = '';
        myOrders.forEach(function(order) {
          tbody.innerHTML += '<tr class="hover-tr"><td class="px-6 py-4 whitespace-nowrap"><span class="text-sm text-gray-300 font-mono">' + order.id + '</span></td><td class="px-6 py-4 whitespace-nowrap"><span class="text-sm text-gray-300">' + order.customer_email + '</span></td><td class="px-6 py-4 whitespace-nowrap"><span class="badge badge-info">' + (regionLabels[order.region] || order.region) + '</span></td><td class="px-6 py-4 whitespace-nowrap"><span class="text-sm text-gray-300">¥' + (order.quote_amount ? order.quote_amount.toLocaleString() : '待报价') + '</span></td><td class="px-6 py-4 whitespace-nowrap"><span class="badge ' + statusColors[order.status] + '">' + statusLabels[order.status] + '</span></td><td class="px-6 py-4 whitespace-nowrap"><span class="text-sm text-gray-400">' + new Date(order.created_at).toLocaleString('zh-CN') + '</span></td><td class="px-6 py-4 whitespace-nowrap"><div class="flex gap-2 flex-wrap"><button class="btn btn-secondary btn-sm" data-action="view-quote" data-id="' + order.id + '">详情</button><button class="btn btn-primary btn-sm" data-action="update-status" data-id="' + order.id + '">更新状态</button></div></td></tr>';
        });
      }

      function updateStats() {
        const pendingCount = myOrders.filter(function(o) { return o.status === 'pending' || o.status === 'quoted'; }).length;
        const completedCount = myOrders.filter(function(o) { return o.status === 'completed' || o.status === 'ordered'; }).length;
        document.getElementById('pendingCount').textContent = pendingCount;
        document.getElementById('completedCount').textContent = completedCount;
        document.getElementById('performance').textContent = '¥' + currentUser.performance_total.toLocaleString();
        document.getElementById('welcomeMsg').textContent = '欢迎回来，' + currentUser.name;
      }

      function renderProfile() {
        document.getElementById('profileName').value = currentUser.name;
        document.getElementById('profileEmail').value = currentUser.email;
        document.getElementById('profilePhone').value = currentUser.phone || '';
        document.getElementById('profileWechat').value = currentUser.wechat || '';
        document.getElementById('profileRegion').value = regionLabels[currentUser.region] || currentUser.region;
      }

      function viewQuote(orderId) {
        const order = myOrders.find(function(o) { return o.id === orderId; });
        if (!order) return;

        const bomItems = [
          { part_number: 'STM32F407VGT6', manufacturer: 'STMicroelectronics', quantity: 100, unit_price: 85.50, lead_time: '4-6 weeks' },
          { part_number: 'TPS65988DHP', manufacturer: 'Texas Instruments', quantity: 50, unit_price: 128.00, lead_time: '6-8 weeks' },
          { part_number: 'MT41K256M16HA-125', manufacturer: 'Micron', quantity: 200, unit_price: 12.30, lead_time: '2-3 weeks' }
        ];

        let bomRows = bomItems.map(function(item) {
          return '<tr><td class="px-4 py-3 text-sm text-gray-300 font-mono">' + item.part_number + '</td><td class="px-4 py-3 text-sm text-gray-300">' + item.manufacturer + '</td><td class="px-4 py-3 text-sm text-gray-300 text-right">' + item.quantity + '</td><td class="px-4 py-3 text-sm text-gray-300 text-right">$' + item.unit_price.toFixed(2) + '</td><td class="px-4 py-3 text-sm text-gray-300 text-right">¥' + (item.unit_price * 7.2 * 1.15).toFixed(2) + '</td><td class="px-4 py-3 text-sm text-gray-300">' + item.lead_time + '</td></tr>';
        }).join('');

        document.getElementById('quoteDetails').innerHTML = '<div class="mb-4"><div class="flex justify-between items-center mb-4"><h4 class="text-white font-medium">BOM 物料清单</h4><span class="badge ' + statusColors[order.status] + '">' + statusLabels[order.status] + '</span></div></div><div class="overflow-x-auto mb-4"><table class="w-full"><thead><tr style="background-color: rgba(55, 65, 81, 0.5);"><th class="px-4 py-3 text-left text-xs font-medium text-gray-400 uppercase">型号</th><th class="px-4 py-3 text-left text-xs font-medium text-gray-400 uppercase">品牌</th><th class="px-4 py-3 text-right text-xs font-medium text-gray-400 uppercase">数量</th><th class="px-4 py-3 text-right text-xs font-medium text-gray-400 uppercase">单价(USD)</th><th class="px-4 py-3 text-right text-xs font-medium text-gray-400 uppercase">报价(RMB)</th><th class="px-4 py-3 text-left text-xs font-medium text-gray-400 uppercase">货期</th></tr></thead><tbody style="border-top-width: 1px; border-top-color: rgba(55, 65, 81, 1);">' + bomRows + '</tbody></table></div><div class="mt-4 pt-4 border-t border-gray-700"><div class="flex justify-between items-center"><div><p class="text-gray-400">客户邮箱</p><p class="text-white">' + order.customer_email + '</p></div><div class="text-right"><p class="text-gray-400">总计</p><p class="text-2xl font-bold text-amber-400">¥' + (order.quote_amount ? order.quote_amount.toLocaleString() : '待报价') + '</p></div></div></div><div class="mt-4 pt-4 border-t border-gray-700 flex justify-end"><button id="closeQuoteBtn" class="btn btn-secondary">关闭</button></div>';

        document.getElementById('quoteModal').classList.add('active');
        document.getElementById('closeQuoteBtn').addEventListener('click', closeQuoteModal);
      }

      function closeQuoteModal() {
        document.getElementById('quoteModal').classList.remove('active');
      }

      function updateOrderStatus(orderId) {
        const order = myOrders.find(function(o) { return o.id === orderId; });
        if (!order) return;

        const statusOptions = ['pending', 'quoted', 'ordered', 'completed', 'cancelled'];
        const currentIndex = statusOptions.indexOf(order.status);
        const nextStatus = statusOptions[(currentIndex + 1) % statusOptions.length];

        if (confirm('确定要将订单状态从"' + statusLabels[order.status] + '"更新为"' + statusLabels[nextStatus] + '"吗？')) {
          order.status = nextStatus;
          renderOrders();
          updateStats();
          alert('订单状态已更新为：' + statusLabels[nextStatus]);
        }
      }

      function handleProfileSubmit(e) {
        e.preventDefault();
        currentUser.name = document.getElementById('profileName').value;
        currentUser.email = document.getElementById('profileEmail').value;
        currentUser.phone = document.getElementById('profilePhone').value;
        currentUser.wechat = document.getElementById('profileWechat').value;
        updateStats();
        alert('个人资料已更新');
      }

      function handlePasswordSubmit(e) {
        e.preventDefault();
        const current = document.getElementById('currentPassword').value;
        const newPwd = document.getElementById('newPassword').value;
        const confirm = document.getElementById('confirmPassword').value;

        if (newPwd !== confirm) {
          alert('两次输入的新密码不一致');
          return;
        }
        if (newPwd.length < 6) {
          alert('新密码长度不能少于6位');
          return;
        }
        alert('密码修改成功');
        document.getElementById('passwordForm').reset();
      }

      document.addEventListener('DOMContentLoaded', function() {
        const userData = localStorage.getItem('currentUser');
        if (userData) {
          try {
            const user = JSON.parse(userData);
            document.getElementById('userName').textContent = user.name || '业务员';
            document.getElementById('userRole').textContent = user.role === 'admin' ? '系统管理员' : (user.role === 'sales' ? '普通业务员' : '客户');
            document.getElementById('userAvatar').textContent = (user.name || 'S').charAt(0).toUpperCase();
          } catch (e) {
            console.error('Failed to parse user data', e);
          }
        }
        
        document.getElementById('nav-orders').addEventListener('click', function() { showSection('orders'); });
        document.getElementById('nav-posts').addEventListener('click', function() { window.location.href = '/dashboard/create-post'; });
        document.getElementById('nav-profile').addEventListener('click', function() { showSection('profile'); renderProfile(); });
        document.getElementById('nav-password').addEventListener('click', function() { showSection('password'); });

        document.getElementById('logoutBtn').addEventListener('click', function() {
          localStorage.removeItem('currentUser');
          window.location.href = '/login';
        });

        document.getElementById('closeQuoteModalBtn').addEventListener('click', closeQuoteModal);

        document.getElementById('orderTableBody').addEventListener('click', function(e) {
          const btn = e.target.closest('button');
          if (!btn) return;
          const action = btn.getAttribute('data-action');
          const id = btn.getAttribute('data-id');
          if (action === 'view-quote') viewQuote(id);
          else if (action === 'update-status') updateOrderStatus(id);
        });

        document.getElementById('profileForm').addEventListener('submit', handleProfileSubmit);
        document.getElementById('passwordForm').addEventListener('submit', handlePasswordSubmit);

        renderOrders();
        updateStats();
        renderProfile();
      });
    </script>
</body>
</html>