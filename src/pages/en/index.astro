---
// src/pages/en/index.astro
// ==========================================
// VETERAN.CORE // ENGLISH HOMEPAGE COMPLETE
// ==========================================
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>VETERAN.CORE // Hardware Expertise & BOM Optimization</title>
    
    <link href="https://fonts.googleapis.com/css2?family=Space+Mono:wght@400;700&family=Inter:wght@400;700&display=swap" rel="stylesheet" />

    <style is:inline>
      /* 全局黑金硬核科技视觉底层 */
      body {
        margin: 0;
        padding: 0;
        background-color: #09090b !important;
        color: #fafafa !important;
        font-family: 'Inter', -apple-system, sans-serif;
        min-height: 100vh;
        display: flex;
        flex-direction: column;
      }

      /* 头部大标题样式 */
      .gveh-header {
        padding: 40px 5%;
        border-bottom: 1px solid rgba(63, 63, 70, 0.4);
      }
      .gveh-logo {
        font-family: 'Space Mono', monospace !important;
        color: #f59e0b !important;
        font-weight: 700;
        letter-spacing: 0.1em;
      }

      /* 核心腹地大字区 */
      .gveh-hero {
        max-width: 1200px;
        margin: 100px auto 60px auto;
        padding: 0 40px;
        text-align: center;
      }
      .gveh-hero h1 {
        font-size: 3.5rem;
        font-weight: 700;
        line-height: 1.2;
        margin-bottom: 24px;
        letter-spacing: -0.02em;
        color: #ffffff;
      }
      .gveh-hero h1 span {
        color: #f59e0b !important;
        font-family: 'Space Mono', monospace !important;
      }
      .gveh-hero p {
        font-size: 1.25rem;
        color: #a1a1aa !important;
        max-width: 800px;
        margin: 0 auto;
        line-height: 1.6;
      }

      /* 三维矩阵卡片区 */
      .gveh-matrix {
        max-width: 1200px;
        margin: 40px auto 160px auto;
        padding: 0 20px;
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 24px;
      }
      .gveh-card {
        background-color: #141417 !important;
        border: 1px solid rgba(63, 63, 70, 0.4) !important;
        padding: 32px;
        border-radius: 4px;
        transition: all 0.3s ease;
      }
      .gveh-card:hover {
        border-color: #f59e0b !important;
        background-color: #18181b !important;
      }
      .gveh-card-tag {
        font-family: 'Space Mono', monospace !important;
        color: #f59e0b !important;
        font-size: 0.75rem;
        margin-bottom: 16px;
      }
      .gveh-card h2 {
        font-size: 1.5rem;
        margin: 0 0 16px 0;
        color: #ffffff;
      }
      .gveh-card p {
        color: #a1a1aa !important;
        font-size: 0.95rem;
        line-height: 1.6;
        margin: 0;
      }

      /* 手机端自适应响应式布线 */
      @media (max-width: 768px) {
        .gveh-hero { margin: 60px auto 30px auto; padding: 0 20px; }
        .gveh-hero h1 { font-size: 2.2rem; }
        .gveh-matrix { grid-template-columns: 1fr; margin-bottom: 140px; padding: 0 20px; }
      }

      /* ==================== 智能感知底栏专属动效样式 ==================== */
      .gveh-nav-container *, .gveh-nav-container a, .gveh-nav-container span {
        font-family: 'Inter', -apple-system, sans-serif !important;
        -webkit-font-smoothing: antialiased;
      }
      .gveh-hover-pill {
        opacity: 0.1 !important;
        transform: translateY(20px) scale(0.98) !important;
        transition: all 0.5s cubic-bezier(0.19, 1, 0.22, 1) !important;
        background-color: rgba(20, 20, 23, 0.3) !important;
        box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1) !important;
      }
      .gveh-nav-container:hover .gveh-hover-pill {
        opacity: 1 !important;
        transform: translateY(0) scale(1) !important;
        background-color: rgba(24, 24, 27, 0.95) !important;
        backdrop-filter: blur(16px) !important;
        -webkit-backdrop-filter: blur(16px) !important;
        border-color: rgba(63, 63, 70, 0.6) !important;
        box-shadow: 0 15px 40px -5px rgba(0, 0, 0, 0.6), 0 12px 18px -8px rgba(245, 158, 11, 0.3) !important;
      }
      /* 手机手机端轻触激活机制 */
      .gveh-nav-container:active .gveh-hover-pill {
        opacity: 1 !important;
        transform: translateY(0) scale(1) !important;
      }
      .gveh-nav-item {
        text-decoration: none !important;
        display: flex !important;
        flex-direction: column !important;
        align-items: center !important;
        gap: 3px !important;
        color: rgba(161, 161, 170, 0.8) !important;
        transition: all 0.3s ease !important;
      }
      .gveh-nav-icon {
        width: 20px !important;
        height: 20px !important;
        stroke-width: 1.5 !important;
        transition: transform 0.3s ease !important;
      }
      .gveh-nav-text {
        font-size: 10px !important;
        font-weight: 700 !important;
        letter-spacing: 0.1em !important;
        text-transform: uppercase !important;
        font-family: 'Space Mono', monospace !important;
      }
      .gveh-nav-item:hover { color: #f59e0b !important; }
      .gveh-nav-item:hover .gveh-nav-icon { transform: scale(1.1) !important; }
      .gveh-nav-item.active { color: #f59e0b !important; }
    </style>
  </head>
  <body>

    <header class="gveh-header">
      <div class="gveh-logo">// VETERAN.CORE //</div>
    </header>

    <main style="flex: 1;">
      <section class="gveh-hero">
        <h1>Don't Just Buy Components.<br />Source with <span>22 Years</span> of Hardware Expertise.</h1>
        <p>[Coordinate: Shenzhen] // Providing independent technical analysis, component optimization, and lifecycle risk mitigation for global engineers.</p>
      </section>

      <section class="gveh-matrix">
        
        <div class="gveh-card">
          <div class="gveh-card-tag">// MODULE_01</div>
          <h2>Domestic vs Global</h2>
          <p>Deep reliability validation, pin-to-pin cross-reference analysis, and transparent alternative options benchmarking tier-1 manufacturers.</p>
        </div>

        <div class="gveh-card">
          <div class="gveh-card-tag">// MODULE_02</div>
          <h2>BOM Optimization</h2>
          <p>Strategic cost reduction without compromising quality. Proactive obsolescence management and resilient supply chain consulting.</p>
        </div>

        <div class="gveh-card">
          <div class="gveh-card-tag">// MODULE_03</div>
          <h2>About Me</h2>
          <p>Rooted in Shenzhen since 2004. 22 years of elite hardware engineering experience acting as your clear, uncompromised eyes on the component market.</p>
        </div>

      </section>
    </main>

    <div class="gveh-nav-container" style="position: fixed !important; bottom: 0 !important; left: 50% !important; transform: translateX(-50%) !important; padding-bottom: 28px !important; padding-top: 50px !important; z-index: 999999 !important; display: flex !important; justify-content: center !important; align-items: center !important; cursor: pointer !important;">
      
      <div class="gveh-hover-pill" style="border: 1px solid rgba(63, 63, 70, 0.1) !important; padding: 7px 22px !important; display: flex !important; justify-content: center !important; align-items: center !important; gap: 32px !important; border-radius: 9999px !important;">
        
        <a href="/" class="gveh-nav-item">
          <svg class="gveh-nav-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
            <path stroke-linecap="round" stroke-linejoin="round" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"></path>
          </svg>
          <span class="gveh-nav-text">HOME</span>
        </a>
        
        <div style="width: 1px !important; height: 18px !important; background-color: rgba(63, 63, 70, 0.4) !important;"></div>

        <a href="/en/bom-hub" class="gveh-nav-item">
          <svg class="gveh-nav-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-3 7h3m-3 4h3m-6-4h.01M9 16h.01"></path>
          </svg>
          <span class="gveh-nav-text">BOM HUB</span>
        </a>

        <div style="width: 1px !important; height: 18px !important; background-color: rgba(63, 63, 70, 0.4) !important;"></div>

        <a href="/en" class="gveh-nav-item active">
          <svg class="gveh-nav-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
            <path stroke-linecap="round" stroke-linejoin="round" d="M21 12a9 9 0 01-9 9m9-9a9 9 0 00-9-9m9 9H3m9 9a9 9 0 01-9-9m9 9c1.657 0 3-4.03 3-9s-1.343-9-3-9m0 18c-1.657 0-3-4.03-3-9s1.343-9 3-9m-9 9a9 9 0 019-9"></path>
          </svg>
          <span class="gveh-nav-text">中 / EN</span>
        </a>

      </div>
    </div>

  </body>
</html>