---
// src/pages/zh/index.astro
// ==========================================
// VETERAN.CORE // CHINESE HOMEPAGE
// ==========================================
// client:load - 确保只在客户端执行数据库查询
---

<html lang="zh-CN">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>胖达原厂严选，元件稳定供应</title>
    
    <link href="https://fonts.googleapis.com/css2?family=Space+Mono:wght@400;700&family=Inter:wght@400;700&display=swap" rel="stylesheet" />

    <style is:inline>
      body {
        margin: 0;
        padding: 0;
        background-color: #09090b !important;
        color: #fafafa !important;
        font-family: 'Inter', sans-serif;
        min-height: 100vh;
        display: flex;
        flex-direction: column;
      }
      
      .gveh-header { 
        padding: 25px 5%; 
        display: flex !important;
        justify-content: space-between !important;
        align-items: flex-start !important;
      }

      .gveh-logo-link {
        text-decoration: none !important;
        display: block !important;
        width: 180px !important;
        position: absolute !important;
        top: 25px !important;
        left: 5% !important;
        z-index: 999 !important;
      }

      .gveh-lang-top-btn {
        text-decoration: none !important;
        font-family: 'Space Mono', monospace !important;
        font-size: 12px !important;
        font-weight: 700 !important;
        color: #aaa !important;
        border: 1px solid #333 !important;
        padding: 6px 12px !important;
        border-radius: 4px !important;
        background: transparent !important;
        transition: all 0.3s ease !important;
      }
      .gveh-lang-top-btn:hover {
        color: #f39c12 !important;
        border-color: #f39c12 !important;
      }

      .gveh-top-right-container {
        position: absolute !important;
        top: 25px !important;
        right: 5% !important;
        z-index: 999 !important;
        display: flex !important;
        align-items: center !important;
        gap: 12px !important;
      }

      .gveh-auth-btn {
        text-decoration: none !important;
        font-family: 'Space Mono', monospace !important;
        font-size: 12px !important;
        font-weight: 700 !important;
        color: #aaa !important;
        border: 1px solid #333 !important;
        padding: 6px 12px !important;
        border-radius: 4px !important;
        background: transparent !important;
        transition: all 0.3s ease !important;
        cursor: pointer !important;
      }

      .gveh-auth-btn:hover {
        color: #f39c12 !important;
        border-color: #f39c12 !important;
      }

      .gveh-user-info {
        display: flex !important;
        align-items: center !important;
        gap: 10px !important;
        cursor: pointer !important;
        padding: 4px 8px !important;
        border-radius: 8px !important;
        transition: background-color 0.3s ease !important;
      }
      .gveh-user-info:hover {
        background-color: rgba(245, 158, 11, 0.1) !important;
      }

      .gveh-user-avatar {
        width: 36px !important;
        height: 36px !important;
        border-radius: 50% !important;
        background: linear-gradient(90deg, #f59e0b, #ea580c) !important;
        display: flex !important;
        align-items: center !important;
        justify-content: center !important;
        font-weight: 700 !important;
        font-size: 14px !important;
        color: #000 !important;
      }

      .gveh-user-details {
        text-align: right !important;
      }

      .gveh-user-name {
        font-weight: 500 !important;
        color: #fff !important;
        font-size: 13px !important;
      }

      .gveh-user-role {
        font-size: 11px !important;
        color: #9ca3af !important;
      }

      .gveh-hero { 
        max-width: 1200px; 
        margin: 180px auto 60px auto; 
        padding: 0 40px; 
        text-align: center; 
      }
      .gveh-hero h1 { 
        font-size: 3.5rem; 
        font-weight: 700; 
        line-height: 1.2; 
        margin-bottom: 24px; 
        color: #ffffff; 
        letter-spacing: -0.02em; 
      }
      .gveh-hero h1 span { 
        color: #f39c12 !important; 
        font-family: 'Space Mono', monospace !important; 
      }
      .gveh-hero p { 
        font-size: 1.25rem; 
        color: #a1a1aa !important; 
        max-width: 800px; 
        margin: 0 auto; 
        line-height: 1.6; 
      }
      
      .gveh-matrix { 
        max-width: 1200px; 
        margin: 40px auto 60px auto; 
        padding: 0 20px; 
        display: grid; 
        grid-template-columns: repeat(3, 1fr); 
        gap: 24px; 
      }
      .gveh-card { 
        background-color: #141417 !important; 
        border: 1px solid rgba(63, 63, 70, 0.4) !important; 
        padding: 32px; 
        border-radius: 4px;
        transition: all 0.3s ease !important;
      }
      .gveh-card:hover {
        border-color: rgba(245, 158, 11, 0.4) !important;
        transform: translateY(-4px);
      }
      .gveh-card-tag { 
        font-family: 'Space Mono', monospace !important; 
        color: #f39c12 !important; 
        font-size: 0.75rem; 
        margin-bottom: 16px; 
      }
      .gveh-card h2 { 
        font-size: 1.5rem; 
        margin: 0 0 16px 0; 
        color: #ffffff; 
      }
      .gveh-card p { 
        color: #a1a1aa !important; 
        font-size: 0.95rem; 
        line-height: 1.6; 
        margin: 0; 
      }

      .gveh-blog-section {
        max-width: 1200px;
        margin: 60px auto 180px auto;
        padding: 0 20px;
      }

      .gveh-section-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 32px;
        padding: 0 20px;
      }

      .gveh-section-title {
        font-size: 1.75rem;
        font-weight: 700;
        color: #fff;
        margin: 0;
      }

      .gveh-section-link {
        font-family: 'Space Mono', monospace !important;
        font-size: 0.875rem;
        color: #f39c12 !important;
        text-decoration: none !important;
        transition: color 0.3s ease !important;
      }
      .gveh-section-link:hover {
        color: #fbbf24 !important;
      }

      .gveh-blog-grid {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: 24px;
      }

      .gveh-blog-card {
        background-color: #141417 !important;
        border: 1px solid rgba(63, 63, 70, 0.4) !important;
        padding: 24px;
        border-radius: 4px;
        transition: all 0.3s ease;
        cursor: pointer;
      }

      .gveh-blog-card:hover {
        border-color: rgba(245, 158, 11, 0.4) !important;
        transform: translateX(4px);
      }

      .gveh-blog-meta {
        display: flex;
        gap: 16px;
        font-size: 0.75rem;
        color: #71717a;
        margin-bottom: 12px;
      }

      .gveh-blog-category {
        font-family: 'Space Mono', monospace !important;
        padding: 2px 8px;
        background-color: rgba(139, 92, 246, 0.15);
        border: 1px solid rgba(139, 92, 246, 0.3);
        border-radius: 4px;
        font-size: 0.7rem;
        color: #a78bfa;
      }

      .gveh-blog-title {
        font-size: 1.125rem;
        font-weight: 600;
        color: #fff;
        margin: 0 0 12px 0;
        line-height: 1.4;
      }

      .gveh-blog-excerpt {
        font-size: 0.9rem;
        color: #a1a1aa;
        line-height: 1.6;
        margin: 0;
        display: -webkit-box;
        -webkit-line-clamp: 3;
        -webkit-box-orient: vertical;
        overflow: hidden;
      }

      .gveh-blog-keywords {
        display: flex;
        flex-wrap: wrap;
        gap: 6px;
        margin-top: 16px;
      }

      .gveh-keyword-tag {
        padding: 3px 10px;
        background-color: rgba(245, 158, 11, 0.1);
        border: 1px solid rgba(245, 158, 11, 0.2);
        border-radius: 9999px;
        font-size: 0.65rem;
        color: #f59e0b;
        font-family: 'Space Mono', monospace;
      }

      .gveh-empty-blog {
        text-align: center;
        padding: 60px 20px;
        color: #71717a;
      }

      .gveh-loading {
        text-align: center;
        padding: 40px 20px;
        color: #71717a;
      }

      .gveh-nav-container {
        position: fixed !important; 
        bottom: 0 !important; 
        left: 50% !important; 
        transform: translateX(-50%) !important;
        padding-bottom: 28px !important; 
        padding-top: 50px !important; 
        z-index: 9999 !important;
        display: flex !important; 
        justify-content: center !important; 
        align-items: center !important; 
        cursor: pointer !important;
      }
      .gveh-hover-pill {
        border: 1px solid rgba(63, 63, 70, 0.2) !important; 
        padding: 8px 24px !important;
        display: flex !important; 
        justify-content: center !important; 
        align-items: center !important; 
        gap: 36px !important; 
        border-radius: 9999px !important;
        opacity: 0.15 !important; 
        transform: translateY(15px) scale(0.98) !important;
        transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1) !important;
        background-color: rgba(20, 20, 23, 0.4) !important; 
        box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1) !important;
      }
      .gveh-nav-container:hover .gveh-hover-pill {
        opacity: 1 !important; 
        transform: translateY(0) scale(1) !important;
        background-color: rgba(24, 24, 27, 0.98) !important;
        backdrop-filter: blur(20px) !important; 
        -webkit-backdrop-filter: blur(20px) !important;
        border-color: rgba(245, 158, 11, 0.4) !important;
        box-shadow: 0 20px 40px rgba(0,0,0,0.7), 0 0 20px rgba(245,158,11,0.15) !important;
      }
      .gveh-nav-item {
        text-decoration: none !important; 
        display: flex !important; 
        flex-direction: column !important;
        align-items: center !important; 
        gap: 3px !important; 
        color: rgba(161, 161, 170, 0.7) !important; 
        transition: all 0.2s ease !important;
      }
      .gveh-nav-text {
        font-size: 10px !important; 
        font-weight: 700 !important; 
        letter-spacing: 0.1em !important;
        text-transform: uppercase !important; 
        font-family: 'Space Mono', monospace !important;
      }
      .gveh-nav-item:hover { 
        color: #f39c12 !important; 
      }
      .gveh-nav-item.active { 
        color: #f39c12 !important; 
      }

      @media (max-width: 768px) {
        .gveh-logo-link {
          width: 130px !important;
          position: static !important;
          margin: 0 auto 20px auto !important;
          display: block !important;
          top: auto !important;
          left: auto !important;
        }
        .gveh-top-right-container {
          position: static !important;
          top: auto !important;
          right: auto !important;
          margin-bottom: 20px !important;
          flex-wrap: wrap !important;
          justify-content: center !important;
        }
        .gveh-header {
          flex-direction: column !important;
          align-items: center !important;
          padding: 20px 5% !important;
        }
        .gveh-hero { 
          margin: 20px auto 30px auto; 
          padding: 0 20px; 
        }
        .gveh-hero h1 { 
          font-size: 2rem; 
        }
        .gveh-matrix { 
          grid-template-columns: 1fr; 
          margin-bottom: 40px; 
          padding: 0 20px; 
        }
        .gveh-blog-grid {
          grid-template-columns: 1fr;
        }
        .gveh-blog-section {
          margin-bottom: 140px;
        }
        img {
          max-width: 130px !important;
          height: auto !important;
          margin: 0 auto !important;
          display: block !important;
        }
        h1 {
          text-align: center !important;
          padding-top: 15px !important;
        }
      }
    </style>
  </head>
  <body>
    <header class="gveh-header">
      <a href="/zh" class="gveh-logo-link">
        <img src="/pnds-logo.png" alt="PNDS Panda Hardware Expertise" style="width: 100% !important; height: auto !important;" />
      </a>
      <div class="gveh-top-right-container">
        <a href="/" class="gveh-lang-top-btn">中文 / EN</a>
        <div id="gveh-auth-container">
          <a href="/login" class="gveh-auth-btn">登录</a>
        </div>
      </div>
    </header>

    <main style="flex: 1;">
      <section class="gveh-hero">
        <h1>不止是采购元器件。<br />凭借<span class="highlight">22年</span>硬件行业积淀，精挑优选每一颗芯片</h1>
        <p>[坐标：深圳] 为全球工程师提供独立技术分析、元器件选型优化与生命周期风险管理。</p>
      </section>

      <section class="gveh-matrix">
        <a href="/zh/blog/category/domestic_vs_global" class="gveh-card" style="text-decoration: none !important;">
          <div class="gveh-card-tag">国产 VS 全球</div>
          <h2>国产 VS 全球</h2>
          <p>深度可靠性验证、引脚级交叉参考分析、透明化替代方案对比一线厂商。</p>
        </a>
        <a href="/zh/blog/category/bom_optimization" class="gveh-card" style="text-decoration: none !important;">
          <div class="gveh-card-tag">BOM 优化</div>
          <h2>BOM 优化</h2>
          <p>战略成本降低而不牺牲质量。主动淘汰管理和弹性供应链咨询服务。</p>
        </a>
        <a href="/zh/blog/category/about_us" class="gveh-card" style="text-decoration: none !important;">
          <div class="gveh-card-tag">关于我</div>
          <h2>关于我</h2>
          <p>2004年扎根深圳，22年精英硬件工程经验，为您在元器件市场保驾护航。</p>
        </a>
      </section>

      <section class="gveh-blog-section">
        <div class="gveh-section-header">
          <h2 class="gveh-section-title">最新文章</h2>
          <a href="/zh/blog" class="gveh-section-link">查看全部 →</a>
        </div>
        
        <div id="blogContainer">
          <div class="gveh-loading">加载文章中...</div>
        </div>
      </section>
    </main>

    <div class="gveh-nav-container">
      <div class="gveh-hover-pill">
        <a href="/zh" class="gveh-nav-item active">
          <svg style="width:18px; height:18px;" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"></path></svg>
          <span class="gveh-nav-text">主页</span>
        </a>
        <div style="width: 1px !important; height: 16px !important; background-color: rgba(63, 63, 70, 0.5) !important;"></div>
        <a href="/zh/bom-hub" class="gveh-nav-item">
          <svg style="width:18px; height:18px;" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-3 7h3m-3 4h3m-6-4h.01M9 16h.01"></path></svg>
          <span class="gveh-nav-text">BOM中心</span>
        </a>
      </div>
    </div>

    <script>
      async function loadBlogs() {
        const container = document.getElementById('blogContainer');
        
        try {
          const response = await fetch('/api/blog/list?limit=6');
          const result = await response.json();
          const blogs = result.data || [];
          
          if (blogs.length > 0) {
            let html = '<div class="gveh-blog-grid">';
            blogs.forEach(blog => {
              const categoryName = blog.category === 'domestic_vs_global' ? '国产 VS 全球' : 
                                  blog.category === 'bom_optimization' ? 'BOM优化' : '关于我们';
              const keywordsHtml = blog.keywords ? blog.keywords.split(',').slice(0, 3).map((keyword, i) => 
                `<span key="${i}" class="gveh-keyword-tag">${keyword.trim()}</span>`
              ).join('') : '';
              
              html += `
                <div class="gveh-blog-card" onclick="window.location.href='/zh/blog/${blog.id}'">
                  <div class="gveh-blog-meta">
                    <span class="gveh-blog-category">${categoryName}</span>
                    <span>${new Date(blog.created_at).toLocaleDateString('zh-CN')}</span>
                  </div>
                  <h3 class="gveh-blog-title">${blog.title_cn || blog.title_en}</h3>
                  <p class="gveh-blog-excerpt">${blog.content_cn || blog.content_en}</p>
                  ${keywordsHtml ? `<div class="gveh-blog-keywords">${keywordsHtml}</div>` : ''}
                </div>
              `;
            });
            html += '</div>';
            container.innerHTML = html;
          } else {
            container.innerHTML = '<div class="gveh-empty-blog"><p>暂无文章，敬请期待...</p></div>';
          }
        } catch (error) {
          console.error('Failed to load blogs:', error);
          container.innerHTML = '<div class="gveh-empty-blog"><p>暂时无法加载文章</p></div>';
        }
      }

      function updateAuthStatus() {
        const authContainer = document.getElementById('gveh-auth-container');
        const userData = localStorage.getItem('currentUser');
        
        if (userData) {
          try {
            const user = JSON.parse(userData);
            const roleText = user.role === 'admin' ? '管理员' : (user.role === 'sales' ? '业务员' : '客户');
            const initial = (user.name || '用').charAt(0).toUpperCase();
            const dashboardUrl = `/dashboard/${user.role}`;
            
            authContainer.innerHTML = `
              <div class="gveh-user-info" onclick="window.location.href='${dashboardUrl}'">
                <div class="gveh-user-details">
                  <div class="gveh-user-name">${user.name || '用户'}</div>
                  <div class="gveh-user-role">${roleText}</div>
                </div>
                <div class="gveh-user-avatar">${initial}</div>
              </div>
            `;
          } catch (e) {
            console.error('Failed to parse user data', e);
          }
        } else {
          authContainer.innerHTML = `
            <a href="/login" class="gveh-auth-btn">登录</a>
          `;
        }
      }
      
      document.addEventListener('DOMContentLoaded', function() {
        updateAuthStatus();
        loadBlogs();
      });
    </script>

  </body>
</html>
